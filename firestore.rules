rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Validation Blueprints
    function isValidTask(data) {
      return data.keys().hasAll(['userId', 'title', 'date', 'status', 'createdAt']) &&
             data.keys().size() <= 8 &&
             data.userId == request.auth.uid &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 200 &&
             data.date is string && data.date.size() <= 30 &&
             data.status in ['pending', 'completed'] &&
             data.createdAt == request.time &&
             (data.get('description', '') is string && data.description.size() <= 1000) &&
             (data.get('color', '') is string && data.color.size() <= 20);
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid == request.auth.uid &&
             data.email is string && data.email.size() <= 100 &&
             (data.get('displayName', '') is string && data.displayName.size() <= 100) &&
             (data.get('photoURL', '') is string && data.photoURL.size() <= 100000);
    }

    // Collection matches
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'email']);
      allow delete: if false; // Users cannot delete profiles for now
    }

    match /tasks/{taskId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isSignedIn() && isValidId(taskId) && isValidTask(incoming());
      
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid && (
        (incoming().diff(existing()).affectedKeys().hasOnly(['title', 'description', 'date', 'status', 'color'])) &&
        isValidTask(incoming())
      );
      
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
  }
}
